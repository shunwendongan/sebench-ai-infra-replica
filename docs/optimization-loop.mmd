flowchart LR
    subgraph Inputs["输入与版本"]
        T["任务规格\nschema + dataset_version"]
        R["仓库快照\nrepo + base_commit"]
        C["Agent 配置\nmodel + prompt + tools"]
        Jv["Judge 版本\nrules + hidden_tests_hash"]
    end

    subgraph Caches["缓存层"]
        I["镜像缓存\nbase/dependency layer"]
        S["快照缓存\ncheckout tarball"]
        M["Repo Map 缓存\nsymbols + dependency graph"]
        P["Prompt 缓存\nstatic context"]
        V["Verdict 缓存\npatch_hash + judge_version"]
    end

    subgraph Runtime["执行与评测"]
        Sch["局部性优先调度器\nrepo/image/runtime buckets"]
        W["Work 容器\nAgent loop + patch"]
        G["提交门禁\npath allowlist + sanitizer"]
        Judge["Judge 级联\nschema -> static -> tests -> LLM"]
    end

    subgraph Metrics["指标与闭环"]
        Run["运行记录\nlatency + cost + cache hits"]
        Fail["失败分类\ntask/context/edit/tool/judge"]
        Report["优化报告\npass_rate + cost_per_pass"]
        Backlog["改进 Backlog\nP0/P1/P2 actions"]
    end

    T --> Sch
    R --> S --> Sch
    C --> P --> W
    Jv --> Judge
    I --> Sch
    M --> W
    Sch --> W --> G --> Judge
    G --> V
    V --> Judge
    Judge --> Run --> Fail --> Report --> Backlog
    Backlog -->|"修复 task spec"| T
    Backlog -->|"改进 context"| M
    Backlog -->|"调优 Agent"| C
    Backlog -->|"稳定 Judge"| Jv
